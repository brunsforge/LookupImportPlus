{
  "name": "lookupimportplus",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Robust Dataverse import/export with controlled lookup resolution (Power Apps Code App)",
  "author": "Andreas Brunsmann (https://github.com/brunsforge)",
  "license": "MIT",
  "homepage": "https://github.com/brunsforge/LookupImportPlus#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brunsforge/LookupImportPlus.git"
  },
  "bugs": {
    "url": "https://github.com/brunsforge/LookupImportPlus/issues"
  },
  "keywords": [
    "power-apps",
    "code-app",
    "dataverse",
    "import",
    "export",
    "lookup",
    "excel",
    "fluent-ui"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit",
    "deploy": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/deploy.ps1"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.54.0",
    "@fluentui/react-icons": "^2.0.245",
    "@microsoft/power-apps": "^1.2.5",
    "exceljs": "^4.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
